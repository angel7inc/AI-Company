# 環境変数テンプレート(実際の値は一切含みません)
# 使い方: このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env 自体は .gitignore で除外されており、GitHubへは絶対に送信されません。
# 本ファイル(.env.example)には、変数名のみを記載し、実在するAPIキー・アクセストークン・
# パスワード・Cookie・クライアントシークレット・実在するユーザーID等は一切記載しません。
#
# 各変数の状態は以下のいずれかです。
#   candidate       = mcp/api-registry.yaml または mcp/servers.yaml で status: candidate として登録済み。未接続
#   planned         = 同上、status: planned として登録済み。未接続
#   not configured  = 現時点で値が設定されていない(このテンプレートの時点では全変数がこの状態)
#
# 変数名は、各サービスの公式ドキュメントで確認できたもののみを記載しています。
# 公式名称を確認できなかったサービス(WordPress・Pinterest・Meta Business・Airtable/Notion・
# Google Trends・n8n・browser/search/memory・booking-payment-api等)は、推測による変数名の
# 記載を避けるため、本ファイルには含めていません(詳細はsecret-management-policy.md・
# 実装報告を参照してください)。

# ==========================================================
# 現在使用中のAPI
# ==========================================================
# 該当なし。mcp/api-registry.yaml・mcp/servers.yamlでstatus: activeなのは
# filesystem-git(Claude Code自体のリポジトリアクセス機構)のみで、これは
# 別途の環境変数を必要としません。

# ==========================================================
# 接続候補(mcp/api-registry.yaml登録済み、status: candidate、未接続)
# ==========================================================

# claude-api(candidate、not configured)― Anthropic公式ドキュメントに基づく変数名
ANTHROPIC_API_KEY=

# chatgpt-api(candidate、not configured)― OpenAI公式ドキュメントに基づく変数名
OPENAI_API_KEY=

# gemini-api(candidate、not configured)― Google Gemini API(AI Studio)の変数名。
# SDKやバージョンにより GOOGLE_API_KEY が使われる場合もあるため、実接続前に公式ドキュメントで再確認すること
GEMINI_API_KEY=

# google-search-console-api / google-analytics-api / youtube-api(いずれもcandidate、not configured)、
# google-drive-sheets(planned、not configured)― Google Cloudのサービスアカウント認証で共通して使う変数名。
# 値は秘密鍵そのものではなく、サービスアカウントJSONファイルへのローカルパスを指定する
GOOGLE_APPLICATION_CREDENTIALS=

# ==========================================================
# 接続候補(mcp/servers.yaml登録済み、status: candidate、未接続)
# ==========================================================

# line-api(candidate、not configured)― LINE公式ドキュメントに基づく変数名(Messaging API)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# slack(candidate、not configured)― Slack公式ドキュメントに基づく変数名(Bot Token)
SLACK_BOT_TOKEN=

# ==========================================================
# 将来利用予定の非秘密共通設定
# ==========================================================
# 注意: 現時点で実行コードは存在せず、これらの変数は読み込まれていません。
# 「将来利用予定の変数名」であり、実装済み・動作中ではありません。

AI_COMPANY_ENV=
AI_COMPANY_TIMEZONE=
AI_COMPANY_LOG_LEVEL=
