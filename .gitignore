# 環境変数・認証情報(絶対にコミットしない)
.env
.env.*
*.key
*.pem
credentials.json
service-account*.json

# 例外: .env.exampleは実値を含まない変数名テンプレートのため、Git管理対象とする(2026-07-14追加)。
# 除外ルールより後ろに書く必要がある(順序が前後すると無効になる)。
!.env.example

# OS/エディタが生成する不要ファイル
.DS_Store
Thumbs.db
desktop.ini
.idea/

# VS Codeの個人用ローカル設定(チーム共有設定は.vscode/settings.json・extensions.jsonのみ追跡)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# 一時ファイル・ログ
*.log
*.tmp

# Finance実績データ(sensitivity: confidential。Private Repositoryでも実額はコミットしない)
_company/finance/actuals/**/*.yaml

# KPI実績データ(Finance実績と同じ扱い。ディレクトリ維持用の.gitkeepのみ追跡)
_company/kpi/actuals/**
!_company/kpi/actuals/.gitkeep

# 機密レポート(実数値を含む週次/月次スナップショット等。.gitkeepのみ追跡)
_company/reports/confidential/**
!_company/reports/confidential/.gitkeep
